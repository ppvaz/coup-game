# Crie um projeto em https://supabase.com e copie os valores em Project Settings > API.
# Estas são chaves públicas, próprias para o cliente web. Nunca use service_role aqui.
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon-publica

# Libera o laboratório 3D após visitar qualquer página com ?labKey=este-valor.
# Em desenvolvimento, quando ausente, o valor padrão é corte-lab.
VITE_CORTE_3D_LAB_KEY=troque-por-um-convite-dificil-de-adivinhar
